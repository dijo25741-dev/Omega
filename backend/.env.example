# Omega Cyber Resilience Core - Environment Configuration

APP_NAME="Omega Cyber Resilience Core"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database Configuration
# Default to SQLite for zero-setup local development
DATABASE_URL=sqlite+aiosqlite:///./omega.db
# PostgreSQL Example:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/omega

# CORS Configuration (JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# Security Settings
SECRET_KEY=super-secret-omega-resilience-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
